# ══════════════════════════════════════════════════════════════
#  MOONSHOT-CEX — Environment Configuration
#  Copy this to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── CORE ──────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=moonshot_cex
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_TINYOFFICE_URL=http://localhost:3001

# ── EXCHANGE MODE ─────────────────────────────────────────────
# paper = simulate internally (no real orders)
# demo  = real orders on Binance Demo / Gate.io Testnet
# live  = production trading
EXCHANGE_MODE=paper
EXCHANGE_NAME=gateio

# ── GATE.IO PRODUCTION ────────────────────────────────────────
GATEIO_API_KEY=
GATEIO_API_SECRET=

# ── GATE.IO TESTNET (DEMO) ────────────────────────────────────
GATEIO_TESTNET_API_KEY=
GATEIO_TESTNET_SECRET_KEY=
GATEIO_TESTNET_URL_Endpoint=https://api-testnet.gateapi.io/api/v4

# ── BINANCE PRODUCTION ────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── BINANCE DEMO ──────────────────────────────────────────────
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
BINANCE_DEMO_URL=https://demo-api.binance.com

# ── KUCOIN (OPTIONAL) ─────────────────────────────────────────
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# ── LLM / AI ─────────────────────────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
OPENROUTER_SECONDARY_MODEL=deepseek/deepseek-v3.2-exp
OPENROUTER_PERPLEXITY_MODEL=perplexity/sonar-pro-search

# ── WATCHER AGENT ─────────────────────────────────────────────
WATCHER_MIN_VOLUME_24H_USD=2000000
WATCHER_TOP_N=20

# ── ANALYZER AGENT ────────────────────────────────────────────
ANALYZER_MIN_SCORE=30.0
ANALYZER_TOP_N=5
ANALYZER_TIMEFRAMES=5m,15m,1h,4h

# ── CONTEXT AGENT ─────────────────────────────────────────────
CONTEXT_AGENT_ENABLED=true
CONTEXT_CACHE_TTL=900

# ── BAYESIAN ENGINE ───────────────────────────────────────────
BAYESIAN_THRESHOLD_NORMAL=0.65
BAYESIAN_THRESHOLD_VOLATILE=0.75
BAYESIAN_THRESHOLD_SAFETY=0.85

# ── RISK MANAGEMENT ───────────────────────────────────────────
MAX_POSITIONS=5
MAX_PORTFOLIO_EXPOSURE_PCT=0.30
MAX_SINGLE_EXPOSURE_PCT=0.08
MAX_RISK_PER_TRADE_PCT=0.01
MAX_DRAWDOWN_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.03
CONSECUTIVE_LOSS_THRESHOLD=3
CONSECUTIVE_LOSS_PAUSE_MINUTES=10
INITIAL_EQUITY_USD=1000.0

# ── POSITION SIZING ───────────────────────────────────────────
POSITION_SIZING_METHOD=half_kelly
KELLY_FRACTION=0.5
MAX_KELLY_FRACTION=0.25
MIN_TRADES_FOR_KELLY=30

# ── EXIT RULES ────────────────────────────────────────────────
STOP_LOSS_PCT=-18.0
TRAILING_STOP_ACTIVATE_PCT=15.0
TRAILING_STOP_DISTANCE_PCT=8.0
TIER1_R_MULTIPLE=2.0
TIER1_EXIT_PCT=0.25
TIER2_R_MULTIPLE=5.0
TIER2_EXIT_PCT=0.25
RUNNER_TRAILING_STOP_PCT=0.03
TIME_EXIT_HOURS=4.0
MAX_SELL_RETRIES=3

# ── PYRAMIDING ────────────────────────────────────────────────
PYRAMID_ENABLED=true
PYRAMID_MAX_ADDS=2
PYRAMID_MIN_R_TO_ADD=1.5

# ── REGIME DETECTION ─────────────────────────────────────────
REGIME_DETECTION_INTERVAL_CYCLES=10
REGIME_BULL_THRESHOLD=3.0
REGIME_BEAR_THRESHOLD=-3.0
REGIME_BULL_EXITS_SL=-22.0
REGIME_BULL_EXITS_TRAIL_ACTIVATE=12.0
REGIME_BULL_EXITS_TRAIL_DIST=9.0
REGIME_BULL_EXITS_TP1=80.0
REGIME_BULL_EXITS_TP2=300.0
REGIME_BULL_EXITS_TIME=5.0
REGIME_SIDEWAYS_EXITS_SL=-18.0
REGIME_SIDEWAYS_EXITS_TRAIL_ACTIVATE=15.0
REGIME_SIDEWAYS_EXITS_TRAIL_DIST=8.0
REGIME_SIDEWAYS_EXITS_TP1=60.0
REGIME_SIDEWAYS_EXITS_TP2=200.0
REGIME_SIDEWAYS_EXITS_TIME=3.0
REGIME_BEAR_EXITS_SL=-12.0
REGIME_BEAR_EXITS_TRAIL_ACTIVATE=20.0
REGIME_BEAR_EXITS_TRAIL_DIST=6.0
REGIME_BEAR_EXITS_TP1=35.0
REGIME_BEAR_EXITS_TP2=80.0
REGIME_BEAR_EXITS_TIME=1.5

# ── QUANT MUTATOR ─────────────────────────────────────────────
QUANT_MUTATOR_EVERY_N_CYCLES=5
MUTATOR_HIGH_WIN_RATE=0.65
MUTATOR_LOW_WIN_RATE=0.40
MUTATOR_MIN_CLOSED_TRADES=5
MUTATOR_SCORE_RAISE_STEP=5.0
MUTATOR_SCORE_LOWER_STEP=3.0
MUTATOR_MIN_SCORE_FLOOR=15.0
MUTATOR_MIN_SCORE_CEILING=60.0

# ── TIMING ────────────────────────────────────────────────────
SWARM_CYCLE_INTERVAL_SECONDS=30
WATCHDOG_INTERVAL_SECONDS=15
NETWORK_ERROR_WAIT_SECONDS=45

# ── ALERTS ────────────────────────────────────────────────────
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=backend/backend.log

# ── SERVER ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
PROMETHEUS_PORT=9090
